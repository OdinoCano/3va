[package]
name = "vvva-rquickjs-sys"
version = "0.6.3"
authors = ["Mees Delzenne <mees.delzenne@gmail.com>"]
edition = "2021"
license = "MIT"
readme = "README.md"
description = "Patched QuickJS C bindings for the 3va runtime (stack-overflow protection, AsyncLocalStorage job-queue, column-number errors)"
keywords = ["quickjs", "javascript", "3va", "runtime", "ffi"]
categories = ["external-ffi-bindings"]
repository = "https://github.com/OdinoCano/3va"
homepage = "https://github.com/OdinoCano/3va"

[build-dependencies]
cc = "1"

[build-dependencies.bindgen-rs]
package = "bindgen"
version = "0.69"
optional = true

[build-dependencies.pretty_env_logger]
version = "0.5"
optional = true

[features]
bindgen = ["bindgen-rs"]

# Debug logging
logging = ["pretty_env_logger"]
# Special case for updating bundled bindings
update-bindings = ["bindgen"]

# Enable QuickJS dumps
dump-bytecode = []
dump-gc = []
dump-gc-free = []
dump-free = []
dump-leaks = []
dump-mem = []
dump-objects = []
dump-atoms = []
dump-shapes = []
dump-module-resolve = []
dump-promise = []
dump-read-object = []
