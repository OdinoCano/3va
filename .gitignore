/target
**/*.rs.bk

# 3va runtime artifacts
node_modules/
.3va-cache/
*.tgz

# OSV audit cache created by vvva_pm tests
crates/pm/.cache/

# npm artifacts (use 3va-lock.json instead)
package-lock.json
yarn.lock

# Platform binaries are downloaded by CI — never committed
dist/npm/linux-x64/bin/
dist/npm/linux-arm64/bin/
dist/npm/darwin-x64/bin/
dist/npm/darwin-arm64/bin/
dist/npm/win32-x64/bin/

# Editor / tooling
.claude/
.kiro
.DS_Store
*.swp
*.swo
.idea/
.vscode/settings.json

# Secrets — never commit
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# Fuzzing artifacts
fuzz/corpus/
fuzz/artifacts/
corpus/

# cargo-tarpaulin coverage outputs
lcov.info
tarpaulin-report.html
cobertura.xml

# cargo-mutants outputs
mutants.out/
mutants.out.old/

# Snap build artifacts
dist/snap/.craft/
dist/snap/parts/
dist/snap/prime/
dist/snap/stage/
dist/snap/*.snap

# Security — estos archivos SÍ van al repo
# .semgrep/   → reglas de seguridad, deben commitearse
# .cargo-husky/ → hooks source, debe commitearse
# Cargo.lock  → trackeado para reproducibilidad y auditoría de supply chain