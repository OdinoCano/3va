        "hash": {
          "url": "https://github.com/OdinoCano/3va/releases/download/v$version/3va-v$version-x86_64-pc-windows-msvc.zip.sha256",
          "regex": "^([a-fA-F0-9]{64})"
        }
      },
      "arm64": {
        "url": "https://github.com/OdinoCano/3va/releases/download/v$version/3va-v$version-aarch64-pc-windows-msvc.zip",
        "hash": {
          "url": "https://github.com/OdinoCano/3va/releases/download/v$version/3va-v$version-aarch64-pc-windows-msvc.zip.sha256",
          "regex": "^([a-fA-F0-9]{64})"
        }
      }
    }
  },
  "notes": "3va blocks post-install scripts unconditionally — this is intentional. Run '3va --help' to get started."
}
