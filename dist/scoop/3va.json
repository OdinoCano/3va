  "homepage": "https://github.com/OdinoCano/3va",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/OdinoCano/3va/releases/download/v1.0.0/3va-v1.0.0-x86_64-pc-windows-msvc.zip",
      "hash": "SHA256_WINDOWS_X64",
      "bin": "3va.exe"
    },
    "arm64": {
      "url": "https://github.com/OdinoCano/3va/releases/download/v1.0.0/3va-v1.0.0-aarch64-pc-windows-msvc.zip",
      "hash": "SHA256_WINDOWS_ARM64",
      "bin": "3va.exe"
    }
  },
  "checkver": {
    "github": "https://github.com/OdinoCano/3va",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
